// API: SMS
// --------------------
void handleNotify() {
  String phone = server.arg("phone");
  String name = server.arg("name");
  String date = server.arg("date");
  String timeValue = server.arg("time");

  String status = "present";
  if (server.hasArg("status")) {
    status = server.arg("status");
  }

  server.send(200, "text/plain", "SMS_PROCESSING");
  sendSMS(phone, name, date, timeValue, status);
}

// --------------------
// API: VERIFY
// --------------------
void handleVerify() {
  if (!server.hasArg("id")) {
    server.send(400, "text/plain", "Missing ID");
    return;
  }

  int expectedID = server.arg("id").toInt();

  Serial.println("Verify request for ID: " + String(expectedID));

  int scannedID = -1;
  int verifyStatus = verifyFingerprintScan(scannedID);

  Serial.println("Verify status: " + String(verifyStatus));
  if (verifyStatus == FP_VERIFY_MATCH) {
    Serial.println("Scanned ID: " + String(scannedID));
    Serial.println("Confidence: " + String(finger.confidence));
  }

  if (verifyStatus == FP_VERIFY_MATCH && scannedID == expectedID) {
    Serial.println("MATCH");
    server.send(200, "text/plain", "MATCH");
  } else if (verifyStatus == FP_VERIFY_MATCH) {
    Serial.println("NO MATCH");
    triggerSecurityAlert();
    server.send(200, "text/plain", "NO_MATCH:" + String(scannedID));
  } else if (verifyStatus == FP_VERIFY_NO_FINGER) {
    Serial.println("NO FINGER");
    server.send(200, "text/plain", "NO_FINGER");
  } else if (verifyStatus == FP_VERIFY_NOT_FOUND) {
    Serial.println("NOT FOUND");
    triggerSecurityAlert();
    server.send(200, "text/plain", "NOT_FOUND");
  } else {
    Serial.println("SENSOR ERROR");
    server.send(200, "text/plain", "SENSOR_ERROR");
  }
}

void handleClearFingerprints() {
  uint8_t result = finger.emptyDatabase();

  Serial.println("Clear fingerprint DB result: " + fpCodeToText(result));

  if (result == FINGERPRINT_OK) {
    finger.getTemplateCount();
    Serial.println("Stored templates: " + String(finger.templateCount));
    server.send(200, "text/plain", "CLEAR_SUCCESS");
  } else {
    server.send(200, "text/plain", "CLEAR_FAILED:" + fpCodeToText(result));
  }
}

// --------------------
// API: ENROLL
// --------------------
void handleEnroll() {
  if (!server.hasArg("id")) {
    server.send(400, "text/plain", "Missing ID");
    return;
  }

  int id = server.arg("id").toInt();

  if (id <= 0) {
    server.send(400, "text/plain", "Invalid ID");
    return;
  }

  Serial.println("Enroll ID: " + String(id));

  uint8_t result = enrollFingerprint(id);

  Serial.println("Enroll result code: " + fpCodeToText(result));

  if (result == FINGERPRINT_OK) {
    server.send(200, "text/plain", "ENROLL_SUCCESS");
  } else {
    server.send(200, "text/plain", "FAILED:" + fpCodeToText(result));
  }
}

// --------------------
// GSM INIT
// --------------------
void initGSM() {
  Serial.println("Initializing GSM...");

  sim800.begin(9600, SERIAL_8N1, GSM_RX, GSM_TX);
  delay(3000);

  modem.restart();

  Serial.print("Connecting GSM");
  while (!modem.waitForNetwork(3000)) {
    Serial.print(".");
  }

  Serial.println("\nGSM connected");
}

// --------------------
// WIFI INIT
// --------------------
void initWiFi() {
  WiFi.mode(WIFI_STA);
  WiFi.begin(ssid, password);

  Serial.print("Connecting WiFi");
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }

  Serial.println("\nWiFi connected");
  Serial.println(WiFi.localIP());

  digitalWrite(BLUE_LED, HIGH);
}

// --------------------
// SETUP
// --------------------
void setup() {
  Serial.begin(115200);

  pinMode(RED_LED, OUTPUT);
  pinMode(GREEN_LED, OUTPUT);
  pinMode(BLUE_LED, OUTPUT);
  pinMode(BUZZER, OUTPUT);
  pinMode(BUTTON, INPUT_PULLUP);

  digitalWrite(RED_LED, LOW);
  digitalWrite(GREEN_LED, LOW);
  digitalWrite(BLUE_LED, LOW);

  fpSerial.begin(57600, SERIAL_8N1, FP_RX, FP_TX);
  finger.begin(57600);

  if (finger.verifyPassword()) {
    Serial.println("Fingerprint sensor connected");

    finger.getTemplateCount();
    Serial.println("Stored templates: " + String(finger.templateCount));
  } else {
    Serial.println("Fingerprint sensor not detected");
  }

  initGSM();
  initWiFi();

  server.on("/attendance", handleAttendance);
  server.on("/health", handleHealth);
  server.on("/unknown", handleUnknown);
  server.on("/notify", handleNotify);
  server.on("/enroll", handleEnroll);
  server.on("/verify", handleVerify);
  server.on("/clear-fingerprints", handleClearFingerprints);

  server.begin();
  Serial.println("Server started");
}

// --------------------
// LOOP
// --------------------
void loop() {
  server.handleClient();

  if (digitalRead(BUTTON) == LOW) {
    Serial.println("Button pressed");
    beep(2000, 150);
    delay(800);
  }
}
