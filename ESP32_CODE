void handleAttendance() {
  String name = server.arg("name");

  digitalWrite(GREEN_LED, HIGH);
  digitalWrite(RED_LED, LOW);

  Serial.println("Attendance marked: " + name);

  beep(2000, 150);

  server.send(200, "text/plain", "OK");

  delay(500);
  digitalWrite(GREEN_LED, LOW);
}

