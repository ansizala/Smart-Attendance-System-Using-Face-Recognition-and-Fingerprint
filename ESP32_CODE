// --------------------
// PIN DEFINITIONS
// --------------------
#define RED_LED 5
#define GREEN_LED 2
#define BLUE_LED 4

#define BUZZER 33
#define BUTTON 32

#define GSM_TX 17
#define GSM_RX 16

#define FP_TX 27
#define FP_RX 26

// --------------------
// WIFI
// --------------------
const char* ssid = "MansiZala";
const char* password = "14032006";

// --------------------
// GLOBALS
// --------------------
WebServer server(80);

HardwareSerial sim800(2);
TinyGsm modem(sim800);

HardwareSerial fpSerial(1);
Adafruit_Fingerprint finger = Adafruit_Fingerprint(&fpSerial);

const uint8_t FP_TIMEOUT_CODE = 254;
const uint8_t FP_REMOVE_TIMEOUT_CODE = 253;
const int FP_VERIFY_MATCH = 1;
const int FP_VERIFY_NO_FINGER = -1;
const int FP_VERIFY_NOT_FOUND = -2;
const int FP_VERIFY_SENSOR_ERROR = -3;

// --------------------
// HELPERS
// --------------------
void beep(int frequency, int durationMs) {
  tone(BUZZER, frequency);
  delay(durationMs);
  noTone(BUZZER);
}

void triggerSecurityAlert(int durationMs = 1200) {
  digitalWrite(RED_LED, HIGH);
  digitalWrite(GREEN_LED, LOW);
  beep(1000, durationMs);
  digitalWrite(RED_LED, LOW);
}

String formatPhone(String phone) {
  phone.replace(" ", "");
  phone.replace("-", "");

  if (phone.length() == 10) {
    phone = "+91" + phone;
  }
  return phone;
}

String fpCodeToText(uint8_t code) {
  switch (code) {
    case FINGERPRINT_OK: return "OK";
    case FINGERPRINT_PACKETRECIEVEERR: return "PACKET_ERROR";
    case FINGERPRINT_NOFINGER: return "NO_FINGER";
    case FINGERPRINT_IMAGEFAIL: return "IMAGE_FAIL";
    case FINGERPRINT_IMAGEMESS: return "IMAGE_MESSY";
    case FINGERPRINT_FEATUREFAIL: return "FEATURE_FAIL";
    case FINGERPRINT_INVALIDIMAGE: return "INVALID_IMAGE";
    case FINGERPRINT_ENROLLMISMATCH: return "ENROLL_MISMATCH";
    case FINGERPRINT_BADLOCATION: return "BAD_LOCATION";
    case FINGERPRINT_FLASHERR: return "FLASH_ERROR";
    case FP_TIMEOUT_CODE: return "TIMEOUT_WAITING_FOR_FINGER";
    case FP_REMOVE_TIMEOUT_CODE: return "TIMEOUT_WAITING_FOR_REMOVAL";
    default: return "UNKNOWN_CODE_" + String(code);
  }
}

uint8_t waitForFinger(unsigned long timeoutMs) {
  unsigned long start = millis();

  while (millis() - start < timeoutMs) {
    uint8_t p = finger.getImage();

    if (p == FINGERPRINT_OK) {
      return p;
    }

    if (p != FINGERPRINT_NOFINGER) {
      Serial.println("getImage: " + fpCodeToText(p));
    }

    delay(50);
  }

  return FP_TIMEOUT_CODE;
}

uint8_t waitForFingerRemoval(unsigned long timeoutMs) {
  unsigned long start = millis();

  while (millis() - start < timeoutMs) {
    uint8_t p = finger.getImage();

    if (p == FINGERPRINT_NOFINGER) {
      return FINGERPRINT_OK;
    }

    delay(50);
  }

  return FP_REMOVE_TIMEOUT_CODE;
}

// --------------------
// SEND SMS
// --------------------
void sendSMS(String phone, String name, String date, String timeValue, String status) {
  phone = formatPhone(phone);

  String msg = "Dear Parent,\n";

  if (status == "absent") {
    msg += name + " is absent.\n";
    msg += "Date: " + date;
  } else {
    msg += name + " attended class.\n";
    msg += "Date: " + date + "\n";
    msg += "Time: " + timeValue;
  }

  Serial.println("Sending SMS to: " + phone);

  if (!modem.waitForNetwork(3000)) {
    Serial.println("GSM network not connected");
    return;
  }

  bool result = modem.sendSMS(phone, msg);

  if (result) Serial.println("SMS sent");
  else Serial.println("SMS failed");
}

// --------------------
// FINGERPRINT VERIFY
// --------------------
int verifyFingerprintScan(int &matchedID) {
  unsigned long start = millis();
  matchedID = -1;

  while (millis() - start < 4000) {
    uint8_t p = finger.getImage();

    if (p == FINGERPRINT_NOFINGER) {
      delay(50);
      continue;
    }

    if (p != FINGERPRINT_OK) {
      Serial.println("getImage failed: " + fpCodeToText(p));
      delay(50);
      continue;
    }

    p = finger.image2Tz();
    if (p != FINGERPRINT_OK) {
      Serial.println("image2Tz failed: " + fpCodeToText(p));
      return FP_VERIFY_SENSOR_ERROR;
    }

    p = finger.fingerSearch();
    if (p == FINGERPRINT_OK) {
      matchedID = finger.fingerID;
      return FP_VERIFY_MATCH;
    }

    if (p == FINGERPRINT_NOTFOUND) {
      Serial.println("fingerSearch: NOT_FOUND");
      return FP_VERIFY_NOT_FOUND;
    }

    Serial.println("fingerSearch failed: " + fpCodeToText(p));
    return FP_VERIFY_SENSOR_ERROR;
  }

  Serial.println("Fingerprint verify timeout");
  return FP_VERIFY_NO_FINGER;
}

// --------------------
// FINGERPRINT ENROLL
// --------------------
uint8_t enrollFingerprint(int id) {
  uint8_t p;

  Serial.println("Place finger...");

  p = waitForFinger(10000);
  if (p != FINGERPRINT_OK) {
    Serial.println("First capture failed: " + fpCodeToText(p));
    return p;
  }

  p = finger.image2Tz(1);
  if (p != FINGERPRINT_OK) {
    Serial.println("image2Tz(1) failed: " + fpCodeToText(p));
    return p;
  }

  Serial.println("Remove finger...");
  p = waitForFingerRemoval(10000);
  if (p != FINGERPRINT_OK) {
    Serial.println("Finger removal failed: " + fpCodeToText(p));
    return p;
  }

  delay(500);
  Serial.println("Place same finger again...");

  p = waitForFinger(10000);
  if (p != FINGERPRINT_OK) {
    Serial.println("Second capture failed: " + fpCodeToText(p));
    return p;
  }

  p = finger.image2Tz(2);
  if (p != FINGERPRINT_OK) {
    Serial.println("image2Tz(2) failed: " + fpCodeToText(p));
    return p;
  }

  p = finger.createModel();
  if (p != FINGERPRINT_OK) {
    Serial.println("createModel failed: " + fpCodeToText(p));
    return p;
  }

  p = finger.storeModel(id);
  Serial.println("storeModel result: " + fpCodeToText(p));
  return p;
}

